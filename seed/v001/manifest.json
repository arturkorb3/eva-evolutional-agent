{
  "name": "eva-layered-core",
  "version": "v001",
  "principle": "organism.py is the tiny non-evolving kernel. A release is a complete, layered bundle: provider-neutral core + model adapters + tool runtime + human/approval + session store, wired by agent.py and gated by supervisor.py/tests.py.",
  "contains": [
    "supervisor.py",
    "agent.py",
    "tests.py",
    "core.py",
    "adapters.py",
    "tools.py",
    "human.py",
    "session.py",
    "self_model.py",
    "tui.py",
    "context.py",
    "evals.py",
    "manifest.json"
  ],
  "layers": {
    "core.py": "provider-neutral semantic model + turn loop",
    "adapters.py": "ModelAdapter implementations (fake, openai_chat, anthropic)",
    "tools.py": "canonical tool schema + sandboxed runtime",
    "human.py": "HumanInterface + ApprovalPolicy",
    "session.py": "canonical append-only event log + compaction",
    "context.py": "compaction policy layer: deterministic LLM-free budgeted view of the log",
    "self_model.py": "generated self-knowledge (anatomy, skills, capabilities) derived from the live release",
    "tui.py": "dependency-free status view: live, human-readable 'what EVA is doing now' tracking",
    "evals.py": "golden-trace evals: replay recorded provider responses through the real adapter+loop+runtime (offline, gate-safe) + guarded live smoke",
    "agent.py": "wiring + CLI (work/improve/review/evolve)",
    "supervisor.py": "release gates + promotion/pivot orchestration",
    "tests.py": "LLM-free checks (ratchet)"
  },
