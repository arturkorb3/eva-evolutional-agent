# Copy this file to .env and fill in your values.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
#
# EVA's core is provider-neutral: it talks to a ModelAdapter, never to a provider
# directly. You pick the adapter EXPLICITLY here (no URL guessing).


# =============================================================================
# 1) PROVIDER SELECTION
# =============================================================================
#   openai_chat  -> OpenAI-compatible Chat Completions (OpenAI, Azure, Ollama,
#                   LM Studio, vLLM, OpenRouter, ...).
#   anthropic    -> Anthropic Claude Messages API (native tools + prompt caching).
#   fake         -> offline, deterministic; for smoke tests / dry runs (no key).
EVA_PROVIDER=openai_chat

# Tool-calling style for openai_chat:
#   native     -> OpenAI function/tool calling (reliable; models are trained for
#                 it). Recommended default.
#   json_text  -> portable JSON-text protocol (for backends WITHOUT native tools,
#                 e.g. some local servers).
EVA_TOOL_MODE=native


# =============================================================================
# 2) MODEL ENDPOINT + CREDENTIALS
# =============================================================================
# --- Option A: OpenAI cloud (Chat Completions) ---
EVA_ENDPOINT=https://api.openai.com/v1/chat/completions
EVA_MODEL=chat-latest
EVA_API_KEY=sk-replace-me

# --- Option B: local model on the host (Ollama / LM Studio) ---
# Comment out Option A and use these instead. host.docker.internal points at
# your host machine from inside the container.
# EVA_ENDPOINT=http://host.docker.internal:11434/v1/chat/completions
# EVA_MODEL=llama3.1
# EVA_API_KEY=ollama

# --- Option C: Anthropic Claude (Messages API) ---
# Set EVA_PROVIDER=anthropic above, then use these. The endpoint defaults to the
# Messages API, so you can leave EVA_ENDPOINT unset (a stale non-/messages URL is
# ignored for this provider).
# EVA_MODEL=claude-sonnet-5
# EVA_API_KEY=sk-ant-replace-me        # or ANTHROPIC_API_KEY
# EVA_ENDPOINT=https://api.anthropic.com/v1/messages
# max_tokens is REQUIRED by the Messages API; EVA defaults to 4096.
# EVA_MAX_TOKENS=4096
# Prompt caching is ON by default (caches the stable system+tools prefix and the
# growing conversation; cache reads cost ~10% of input). Set to 0 to disable.
# EVA_PROMPT_CACHE=1

# Note: legacy names still work as a fallback if the EVA_* vars are unset:
#   LLM_ENDPOINT / LLM_MODEL / LLM_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY

# Sampling temperature is OPT-IN: many current models reject a non-default value
# with HTTP 400, so EVA omits it unless you set this explicitly.
# EVA_TEMPERATURE=0.2


# =============================================================================
# 3) REQUEST TIMEOUT (seconds, optional)
# =============================================================================
# Raise this if you see "read operation timed out" with slow models on large
# inputs. Default is 180.
# LLM_TIMEOUT=180


# =============================================================================
# 4) CONVERSATION CONTEXT BUDGET (characters, optional)
# =============================================================================
# The full event log is the source of truth on disk. Only the SENT view is
# compacted: the full history is sent while it fits this budget; past it, older
# turns collapse into a short deterministic summary + the last few turns.
ORGANISM_HISTORY_BUDGET=48000
ORGANISM_HISTORY_KEEP=10


# =============================================================================
# 5) AUTONOMOUS MODE (NO per-step approval, optional)
# =============================================================================
# Safe to enable only because the container sandbox contains EVA. Equivalent to
# passing --yes --allow-shell on the command line. ORGANISM_AUTO_YES switches the
# approval policy to "never"; ORGANISM_ALLOW_SHELL auto-approves non-read-only
# shell (read-only shell is always auto-approved).
# ORGANISM_AUTO_YES=1
# ORGANISM_ALLOW_SHELL=1

# Optional: how many repeats of the same friction before work asks to pivot to an
# improve cycle (default 3).
# ORGANISM_PIVOT_THRESHOLD=3


# =============================================================================
# 6) DISPLAY / TUI (optional)
# =============================================================================
# The status view is compact by default (truncated commands, first lines of
# output). Set EVA_TUI_FULL=1 to always expand full commands and complete output.
# (You can also press `f` at an approval prompt to reveal just that command.)
# EVA_TUI_FULL=1

# Disable ANSI colour in the status view (also honoured: a non-TTY stream).
# NO_COLOR=1

# Stream assistant text token-by-token (live typing) as it arrives, for providers
# that support it (openai_chat native + anthropic). ON by default. Only free text is
# streamed; tool calls are still shown whole. Set to 0 to wait for the full reply.
# EVA_STREAM=1
