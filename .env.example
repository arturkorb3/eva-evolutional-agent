# Copy this file to .env and fill in your values.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env

# --- Option A: OpenAI via the Responses API (default bootstrap) ---
# The provider layer auto-detects the API shape from the endpoint path:
#   .../responses         -> OpenAI Responses API
#   .../chat/completions  -> Chat Completions (OpenAI-compatible servers)
LLM_ENDPOINT=https://api.openai.com/v1/responses
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-replace-me

# --- Option B: local model on the host (Ollama / LM Studio) ---
# Comment out Option A and use these instead. host.docker.internal points at
# your host machine from inside the container.
# LLM_ENDPOINT=http://host.docker.internal:11434/v1/chat/completions
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama

# --- Optional: fully autonomous mode (NO per-step approval) ---
# Safe to enable only because the container sandbox contains EVA. Equivalent to
# passing --yes --allow-shell on the command line.
# ORGANISM_AUTO_YES=1
# ORGANISM_ALLOW_SHELL=1
